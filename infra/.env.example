# 복사해서 infra/.env 로 두고 값 채우기 (gitignored).

# Postgres
POSTGRES_USER=openwebui
POSTGRES_PASSWORD=change_me_dev_only
POSTGRES_DB=openwebui

# open-webui
WEBUI_SECRET_KEY=  # openssl rand -hex 32
SSO_SECRET=        # openssl rand -hex 32 — Worker(.dev.vars) 와 동일 값

# LLM 키 (없어도 dev 진입은 가능, 채팅 호출 시점에 실패)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# 외부 API (선택)
LAW_API_KEY=
